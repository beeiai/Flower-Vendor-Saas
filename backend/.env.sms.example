# ========================
# SMS Configuration (Fast2SMS with BSNL DLT)
# ========================

# Fast2SMS API Base URL
# For DLT route: https://www.fast2sms.com/dev/bulkV2
# For normal route: https://www.fast2sms.com/dev/bulk
SMS_API_URL=https://www.fast2sms.com/dev/bulkV2

# Fast2SMS API Key (Authorization token)
# Get this from your Fast2SMS dashboard after registration
SMS_API_KEY=your_fast2sms_api_key_here

# Sender ID (Header) registered on BSNL DLT
# Example: FLOWER, MYSHOP, etc.
# This must match the approved Sender ID from BSNL DLT portal
SMS_SENDER_ID=FLOWER

# Entity ID (PE ID) registered on BSNL DLT
# This is your Principal Entity ID provided by BSNL after approval
SMS_ENTITY_ID=your_entity_id_here

# Template ID registered on BSNL DLT
# This is the unique ID for your approved SMS template
# Example: 1707500000000001234
SMS_TEMPLATE_ID=your_template_id_here

# SMS Route Type
# Use "dlt" for DLT-compliant messages (recommended)
# Use "normal" or "transactional" for non-DLT messages
SMS_DLT_ROUTE=dlt

# Maximum retry attempts for failed SMS
SMS_MAX_RETRY=3
